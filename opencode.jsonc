{
  "$schema": "https://opencode.ai/config.json",

  // Restringe o OpenCode à chave da Anthropic.
  "enabled_providers": ["anthropic"],

  // Modelo barato como padrão de segurança.
  "model": "anthropic/claude-haiku-4-5",
  "small_model": "anthropic/claude-haiku-4-5",

  // Sempre começa analisando, sem editar.
  "default_agent": "plan",

  // Não gera links públicos das sessões.
  "share": "disabled",

  "provider": {
    "anthropic": {
      "options": {
        // A chave fica na variável de ambiente, não neste arquivo.
        "apiKey": "{env:ANTHROPIC_API_KEY}",

        // Mantém uma chave consistente para cache.
        "setCacheKey": true
      },

      "models": {
        "claude-sonnet-5": {
          "options": {
            // Evita tokens extras de raciocínio em tarefas normais.
            "thinking": {
              "type": "disabled"
            }
          }
        }
      }
    }
  },

  "compaction": {
    "auto": true,

    // Remove resultados antigos de ferramentas do contexto.
    "prune": true,

    // Reserva espaço para produzir o resumo da sessão.
    "reserved": 12000
  },

  "watcher": {
    "ignore": [
      ".git/**",
      "node_modules/**",
      "vendor/**",
      "dist/**",
      "build/**",
      "coverage/**",
      ".next/**",
      ".nuxt/**",
      "target/**",
      "bin/**",
      "obj/**",
      "tmp/**",
      "temp/**",
      "logs/**",
      "**/*.log",
      "**/*.map",
      "**/*.min.js",
      "package-lock.json",
      "pnpm-lock.yaml",
      "yarn.lock",
      ".env",
      ".env.*",
      "secrets/**"
    ]
  },

  "permission": {
    "read": {
      "*": "allow",
      "*.env": "deny",
      "*.env.*": "deny",
      "*.env.example": "allow",
      "**/secrets/**": "deny",
      "**/credentials*": "deny"
    },

    // Impede o agente de sair da pasta do projeto.
    "external_directory": "deny",

    // Evita pesquisas externas automáticas e resultados enormes.
    "websearch": "ask",
    "webfetch": "ask",

    // Bloqueia repetição idêntica de ferramentas.
    "doom_loop": "deny"
  },

  "agent": {
    "plan": {
      "description": "Planejamento econômico e somente leitura",
      "mode": "primary",
      "model": "anthropic/claude-haiku-4-5",

      // Evita exploração interminável.
      "steps": 6,

      "permission": {
        "edit": "deny",
        "bash": "deny",

        // Permite apenas o explorador barato.
        "task": {
          "*": "deny",
          "explore": "allow"
        }
      }
    },

    "build": {
      "description": "Implementação controlada com Claude Sonnet",
      "mode": "primary",
      "model": "anthropic/claude-sonnet-5",

      // Sonnet 5 usa adaptive thinking por padrão.
      // Desativar reduz custo em tarefas comuns.
      "thinking": {
        "type": "disabled"
      },

      // Limite importante para impedir ciclos caros.
      "steps": 12,

      "permission": {
        "edit": "ask",

        "bash": {
          "*": "ask",

          // Comandos baratos e somente leitura.
          "git status*": "allow",
          "git diff*": "allow",
          "git log*": "allow",
          "git show*": "allow",
          "rg *": "allow",
          "grep *": "allow",

          // Nunca executar automaticamente.
          "git push*": "deny",
          "rm *": "deny"
        },

        "task": {
          "*": "deny",
          "explore": "allow"
        },

        "websearch": "ask",
        "webfetch": "ask"
      }
    },

    "explore": {
      "description": "Localiza arquivos e código usando Haiku",
      "mode": "subagent",
      "model": "anthropic/claude-haiku-4-5",
      "steps": 5,

      "permission": {
        "edit": "deny",
        "bash": "deny",
        "task": "deny",
        "websearch": "deny",
        "webfetch": "deny"
      }
    },

    // Evita subagentes caros ou paralelos sendo iniciados sozinhos.
    "general": {
      "disable": true
    },

    "scout": {
      "disable": true
    }
  },

  // Não carregue MCPs ou plugins enquanto não forem necessários.
  "mcp": {},
  "plugin": [],

  // Mantenha este arquivo curto.
  "instructions": ["AGENTS.md"],

  // Ajuda a localizar símbolos sem ler arquivos inteiros.
  "lsp": true
}
