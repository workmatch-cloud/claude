{
  "$schema": "https://opencode.ai/config.json",

  // Restrict OpenCode to the Anthropic provider.
  "enabled_providers": ["anthropic"],

  // Use the lower-cost model as the safe default.
  "model": "anthropic/claude-haiku-4-5",
  "small_model": "anthropic/claude-haiku-4-5",

  // Always start in analysis-only mode without editing files.
  "default_agent": "plan",

  // Do not generate public session links.
  "share": "disabled",

  "provider": {
    "anthropic": {
      "options": {
        // Read the API key from the environment instead of storing it here.
        "apiKey": "{env:ANTHROPIC_API_KEY}",

        // Use a stable prompt cache key when supported.
        "setCacheKey": true
      },

      "models": {
        "claude-sonnet-5": {
          "options": {
            // Claude Sonnet 5 enables adaptive thinking by default.
            // Disable it for routine tasks to reduce reasoning-token usage.
            "thinking": {
              "type": "disabled"
            }
          }
        }
      }
    }
  },

  "compaction": {
    "auto": true,

    // Remove old tool results from the active context.
    "prune": true,

    // Reserve enough context space to generate the session summary.
    "reserved": 12000
  },

  "watcher": {
    "ignore": [
      ".git/**",
      "node_modules/**",
      "vendor/**",
      "dist/**",
      "build/**",
      "coverage/**",
      ".next/**",
      ".nuxt/**",
      "target/**",
      "bin/**",
      "obj/**",
      "tmp/**",
      "temp/**",
      "logs/**",
      "**/*.log",
      "**/*.map",
      "**/*.min.js",
      "package-lock.json",
      "pnpm-lock.yaml",
      "yarn.lock",
      ".env",
      ".env.*",
      "secrets/**"
    ]
  },

  "permission": {
    "read": {
      "*": "allow",
      "*.env": "deny",
      "*.env.*": "deny",
      "*.env.example": "allow",
      "**/secrets/**": "deny",
      "**/credentials*": "deny"
    },

    // Prevent agents from accessing paths outside the project directory.
    "external_directory": "deny",

    // Require approval before external searches or URL fetches.
    "websearch": "ask",
    "webfetch": "ask",

    // Block identical tool calls from repeating in a loop.
    "doom_loop": "deny"
  },

  "agent": {
    "plan": {
      "description": "Cost-conscious, read-only planning and analysis",
      "mode": "primary",
      "model": "anthropic/claude-haiku-4-5",

      // Limit prolonged exploratory loops.
      "steps": 6,

      "permission": {
        "edit": "deny",
        "bash": "deny",

        // Allow only the lower-cost read-only explorer.
        "task": {
          "*": "deny",
          "explore": "allow"
        }
      }
    },

    "build": {
      "description": "Controlled implementation with Claude Sonnet",
      "mode": "primary",
      "model": "anthropic/claude-sonnet-5",

      // Model-specific agent options belong under "options".
      "options": {
        // Claude Sonnet 5 enables adaptive thinking by default.
        // Disable it for routine implementation work.
        "thinking": {
          "type": "disabled"
        }
      },

      // Prevent expensive, open-ended implementation loops.
      "steps": 12,

      "permission": {
        "edit": "ask",

        "bash": {
          "*": "ask",

          // Low-risk, read-only commands.
          "git status*": "allow",
          "git diff*": "allow",
          "git log*": "allow",
          "git show*": "allow",
          "rg *": "allow",
          "grep *": "allow",

          // Never run these automatically.
          "git push*": "deny",
          "rm *": "deny"
        },

        "task": {
          "*": "deny",
          "explore": "allow"
        },

        "websearch": "ask",
        "webfetch": "ask"
      }
    },

    "explore": {
      "description": "Locate files and code with Claude Haiku",
      "mode": "subagent",
      "model": "anthropic/claude-haiku-4-5",
      "steps": 5,

      "permission": {
        "edit": "deny",
        "bash": "deny",
        "task": "deny",
        "websearch": "deny",
        "webfetch": "deny"
      }
    },

    // Prevent expensive or parallel subagents from starting automatically.
    "general": {
      "disable": true
    },

    "scout": {
      "disable": true
    }
  },

  // Load no MCP servers or plugins until explicitly required.
  "mcp": {},
  "plugin": [],

  // Keep repository-specific instructions in a separate, short file.
  "instructions": ["AGENTS.md"],

  // Enable language-server support for symbol navigation.
  "lsp": true
}
