{
  "$schema": "https://opencode.ai/config.json",

  // Restrict OpenCode to the Anthropic provider.
  "enabled_providers": ["anthropic"],

  // Use the lower-cost model for normal and lightweight tasks.
  "model": "anthropic/claude-haiku-4-5",
  "small_model": "anthropic/claude-haiku-4-5",

  // Always begin with read-only planning.
  "default_agent": "plan",

  // Disable public session sharing.
  "share": "disabled",

  "provider": {
    "anthropic": {
      "options": {
        // Read the API key from the environment.
        "apiKey": "{env:ANTHROPIC_API_KEY}",

        // Keep a stable cache key when supported.
        "setCacheKey": true
      },

      "models": {
        "claude-sonnet-5": {
          "options": {
            // Disable adaptive thinking for routine implementation work.
            "thinking": {
              "type": "disabled"
            }
          }
        }
      }
    }
  },

  "compaction": {
    // Automatically compact long sessions.
    "auto": true,

    // Remove old tool outputs from the active context.
    "prune": true,

    // Keep enough context space available for compaction.
    "reserved": 12000
  },

  "watcher": {
    "ignore": [
      ".git/**",
      "node_modules/**",
      "vendor/**",
      "dist/**",
      "build/**",
      "coverage/**",
      ".next/**",
      ".nuxt/**",
      "target/**",
      "bin/**",
      "obj/**",
      "tmp/**",
      "temp/**",
      "logs/**",
      "**/*.log",
      "**/*.map",
      "**/*.min.js",
      "package-lock.json",
      "pnpm-lock.yaml",
      "yarn.lock",
      ".env",
      ".env.*",
      "secrets/**"
    ]
  },

  "permission": {
    "read": {
      "*": "allow",
      "*.env": "deny",
      "*.env.*": "deny",
      "*.env.example": "allow",
      "**/secrets/**": "deny",
      "**/credentials*": "deny"
    },

    // Prevent access outside the active project.
    "external_directory": "deny",

    // Require approval before external research.
    "websearch": "ask",
    "webfetch": "ask",

    // Block identical tool calls when the agent appears stuck.
    "doom_loop": "deny"
  },

  "agent": {
    "plan": {
      "description": "Low-cost, read-only planning and analysis",
      "mode": "primary",
      "model": "anthropic/claude-haiku-4-5",

      // Keep planning focused and deterministic.
      "temperature": 0.1,

      // Encourage short answers and minimal repository exploration.
      "prompt": "Be concise. Inspect only files relevant to the request. Avoid repeated summaries and broad repository scans. Use the explore subagent only when necessary. Stop when the requested plan is complete.",

      // Reduce the maximum number of agentic iterations.
      "steps": 4,

      "permission": {
        "edit": "deny",
        "bash": "deny",
        "todowrite": "deny",

        // Allow only the low-cost read-only explorer.
        "task": {
          "*": "deny",
          "explore": "allow"
        },

        // Keep external research out of routine planning.
        "websearch": "deny",
        "webfetch": "deny"
      }
    },

    "build": {
      "description": "Controlled and token-conscious implementation",
      "mode": "primary",
      "model": "anthropic/claude-sonnet-5",

      // Keep implementation focused and deterministic.
      "temperature": 0.1,

      // These additional agent options are passed to Anthropic.
      "thinking": {
        "type": "disabled"
      },

      // Encourage minimal patches and short completion messages.
      "prompt": "Make the smallest correct change. Read only relevant files. Avoid broad scans, repeated summaries, speculative work, and unrelated improvements. Do not invoke subagents. Stop after completing and briefly verifying the requested change.",

      // Reduce expensive implementation loops.
      "steps": 8,

      "permission": {
        "edit": "ask",
        "todowrite": "deny",

        "bash": {
          "*": "ask",

          // Low-risk, read-only commands.
          "git status*": "allow",
          "git diff*": "allow",
          "git log*": "allow",
          "git show*": "allow",
          "rg *": "allow",
          "grep *": "allow",

          // Never execute automatically.
          "git push*": "deny",
          "rm *": "deny"
        },

        // Prevent extra model sessions during implementation.
        "task": "deny",

        "websearch": "ask",
        "webfetch": "ask"
      }
    },

    "explore": {
      "description": "Locate only the minimum relevant files and symbols",
      "mode": "subagent",
      "model": "anthropic/claude-haiku-4-5",

      "temperature": 0.1,

      "prompt": "Find only the minimum files, symbols, and code needed for the parent request. Return paths and brief findings. Do not summarize unrelated code or continue after locating the required information.",

      // Keep exploration short.
      "steps": 3,

      "permission": {
        "edit": "deny",
        "bash": "deny",
        "task": "deny",
        "todowrite": "deny",
        "websearch": "deny",
        "webfetch": "deny"
      }
    },

    // Disable broad or parallel subagents.
    "general": {
      "disable": true
    },

    "scout": {
      "disable": true
    }
  },

  // Load no MCP servers or plugins by default.
  "mcp": {},
  "plugin": [],

  // Keep project-specific instructions short.
  "instructions": ["AGENTS.md"],

  // Use language servers to locate symbols without reading entire files.
  "lsp": true
}
